    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.11",
    "gemoji": "^8.1.0",
    "lucide-react": "^1.17.0",
    "marked": "^18.0.5",
    "marked-alert": "^2.1.2",
    "marked-emoji": "^2.0.3",
    "marked-footnote": "^1.4.0",
